name: Deploy to AWS S3

on:
  push:
    branches:
      - main # Se ejecuta cuando hay cambios en la rama main

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      # 1. Clonar el repositorio
      - name: Checkout código
        uses: actions/checkout@v3

      # 2. Instalar Node.js
      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'

      # 3. Instalar dependencias y Minificar (crear la carpeta dist/)
      - name: Instalar y Compilar
        run: |
          npm install
          npm run build

      # 4. Configurar credenciales de AWS
      - name: Configurar AWS
        uses: aws-actions/configure-aws-credentials@v2
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: us-east-1 # Cambia esto por tu región de AWS

      # 5. Subir la carpeta dist/ al Bucket de S3
      - name: Subir a S3
        run: aws s3 sync ./dist s3://paulbase.cloud --delete